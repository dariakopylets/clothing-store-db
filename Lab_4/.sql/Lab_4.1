-- Базова агрегація (COUNT, SUM, AVG, MIN, MAX)

-- 1.Кількість унікальних клієнтів у client
SELECT COUNT(DISTINCT client_id) as total_clients
 FROM client;

-- 2.Кількість всіх замовлень, зафіксованих у order_
SELECT COUNT(*) as total_orders
 FROM order_;

-- 3.Загальна сума вартості всіх доданих у корзину товарів
SELECT SUM(price * quantity) as total_cart_value
 FROM cart;

-- 4.Обчислити середню ціну товару
SELECT ROUND(AVG(price), 2) as average_product_price
 FROM products;

-- 5.Знаходження найстарішої дати народження клієнта
SELECT MIN(birthday) as oldest_client
 FROM client;

-- 6.Знаходження найбільшої ціни одного товару
SELECT MAX(price) as highest_price
 FROM products;
